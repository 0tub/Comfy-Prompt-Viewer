<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ComfyPromptViewer.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
            <FontFamily x:Key="FontHeading">avares://ComfyPromptViewer/Assets/Fonts#Fraunces</FontFamily>
            <FontFamily x:Key="FontMono">avares://ComfyPromptViewer/Assets/Fonts#Geist Mono</FontFamily>
            <FontFamily x:Key="FontUI">avares://ComfyPromptViewer/Assets/Fonts#Noto Sans</FontFamily>

            <Color x:Key="SystemAccentColor">#8B3A2E</Color>
            <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#8B3A2E" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#8B3A2E" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#8B3A2E" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#8B3A2E" />
            <SolidColorBrush x:Key="BackgroundBase" Color="#17120D" />
            <SolidColorBrush x:Key="SurfaceBase" Color="#17120D" />
            <SolidColorBrush x:Key="SurfaceCard" Color="#272016" />
            <SolidColorBrush x:Key="SurfaceSidebar" Color="#1C1610" />
            <SolidColorBrush x:Key="SurfaceElevated" Color="#261E16" />
            <SolidColorBrush x:Key="SurfaceInput" Color="#2C2318" />
            <SolidColorBrush x:Key="BorderSubtle" Color="#3A2E22" />
            <SolidColorBrush x:Key="ToolbarBorderSubtle" Color="#4A3A2A" />
            <SolidColorBrush x:Key="BorderAccent" Color="#8B3A2E" />
            <SolidColorBrush x:Key="CardHoverBorder" Color="#4A3D30" />
            <SolidColorBrush x:Key="TextPrimary" Color="#F5EDE0" />
            <SolidColorBrush x:Key="TextSecondary" Color="#C4AE92" />
            <SolidColorBrush x:Key="TextMuted" Color="#8C7660" />
            <SolidColorBrush x:Key="TextAccent" Color="#D4795A" />
            <SolidColorBrush x:Key="PromptText" Color="#C4AE92" />
            <SolidColorBrush x:Key="EmptyStateSubtext" Color="#74604E" />
            <SolidColorBrush x:Key="LiveDotText" Color="#5A8A5A" />
            <SolidColorBrush x:Key="DangerSurface" Color="#2D1F21" />
            <SolidColorBrush x:Key="DangerBorder" Color="#5C262C" />
            <SolidColorBrush x:Key="DangerText" Color="#F0B2A8" />

            <!-- Slider Overrides to Prevent Green Accent Color -->
            <SolidColorBrush x:Key="SliderThumbBackground" Color="#8B3A2E" />
            <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#D4795A" />
            <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#8B3A2E" />
            <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="#3A2E22" />

            <SolidColorBrush x:Key="SliderTrackFill" Color="#3A2E22" />
            <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#3A2E22" />
            <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#3A2E22" />
            <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#2C2318" />

            <SolidColorBrush x:Key="SliderTrackValueFill" Color="#8B3A2E" />
            <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#8B3A2E" />
            <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#8B3A2E" />
            <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="#3A2E22" />

            <!-- ComboBox Theme Overrides to Match App Aesthetic -->
            <SolidColorBrush x:Key="ComboBoxBackground" Color="#2C2318" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#261E16" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#2C2318" />
            <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="#1C1610" />
            
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#3A2E22" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#8B3A2E" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#8B3A2E" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled" Color="#3A2E22" />
            
            <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#272016" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#272016" />
            <SolidColorBrush x:Key="ComboBoxDropdownBorderBrush" Color="#3A2E22" />
            <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#3A2E22" />
            
            <SolidColorBrush x:Key="ComboBoxForeground" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="#8C7660" />

            <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#2C2318" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="#2C2318" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#8B3A2E" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#A64A3D" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#8B3A2E" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundDisabled" Color="Transparent" />

            <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#C4AE92" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundPressed" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="#F5EDE0" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundDisabled" Color="#8C7660" />

            <!-- ContextMenu / MenuFlyout Overrides to Match Theme -->
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#17120D" />
            <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#3A2E22" />
            <Thickness x:Key="MenuFlyoutPresenterBorderThickness">1</Thickness>
            <CornerRadius x:Key="MenuFlyoutPresenterCornerRadius">6</CornerRadius>

            <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="#272016" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="#2C2318" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundDisabled" Color="Transparent" />

            <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="#C4AE92" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="#F5EDE0" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="#F5EDE0" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled" Color="#8C7660" />
        </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource SurfaceCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource MenuFlyoutPresenterBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MenuFlyoutPresenterBorderBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource MenuFlyoutPresenterBorderThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource MenuFlyoutPresenterCornerRadius}" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForeground}" />
            <Setter Property="Background" Value="{DynamicResource MenuFlyoutItemBackground}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <Style Selector="ContextMenu Separator">
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
    </Application.Styles>
</Application>
